{
  "name": "andes-crypto-deposit-backend",
  "version": "1.0.0",
  "description": "Production-ready crypto deposit backend for Andes platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "crypto",
    "deposits",
    "blockchain",
    "ethereum",
    "tron",
    "bsc",
    "polygon"
  ],
  "author": "Andes Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.7.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "hdkey": "^2.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "mongoose": "^7.5.0",
    "node-cron": "^3.0.2",
    "tronweb": "^4.4.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.20",
    "@types/hdkey": "^2.1.0",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
